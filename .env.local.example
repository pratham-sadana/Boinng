# BOINNG! Storefront Configuration
# Using Shopify Headless/Custom App
# Copy this to .env.local and fill in your API token

# ─── Your Store Details ──────────────────────────────────────────────────────
# Store: gnnh16-hf.myshopify.com

# ⭐ Use the PUBLIC / STOREFRONT API TOKEN (not the private one!)
# Your Shopify headless app has TWO tokens:
#   1. PUBLIC TOKEN (Storefront API) ← USE THIS ONE for frontend
#   2. PRIVATE TOKEN (Admin API) ← Use only for server-side code
#
# 📍 Get from: Shopify Admin > Apps and integrations > Your Headless App
# Look for section: "Storefront API" or "Public access token"
# Token format: shpca_abc123... or shpua_abc123...
#
# See: GET_HEADLESS_TOKEN.md for detailed step-by-step instructions
SHOPIFY_STOREFRONT_ACCESS_TOKEN=ec45b6a53a3f5b9bea8ae7674d1fbf4c

# API endpoint will be constructed as:
# https://gnnh16-hf.myshopify.com/api/2024-01/graphql.json

# ─── Notes ───────────────────────────────────────────────────────────────────
# • STOREFRONT token: Safe to expose in browser/frontend
# • ADMIN token: Keep private, server-side only
# • Never commit .env.local to git (in .gitignore)
# • If token is exposed, regenerate it in Shopify Admin

